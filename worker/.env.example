# Worker secrets — DO NOT commit the filled-in version. Service-role key has full
# DB access; keep it server-side only (never in the mobile app).
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
PROOFS_BUCKET=proofs

# Runtime tuning (optional)
ENABLE_POLLER=true
POLL_INTERVAL_SECONDS=5
POLL_BATCH=4
MAX_FRAMES=900
TOKEN_SCAN_SECONDS=6
