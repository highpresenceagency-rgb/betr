{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": { 
    
    "production": {
      "ios": {
        "appleId": "replace-with-your-apple-id@email.com",
        "ascAppId": "replace-with-your-app-store-connect-app-id",
        "appleTeamId": "replace-with-your-apple-team-id"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "production"
      }
    }
  }
}
